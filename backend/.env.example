DEBUG=True
SECRET_KEY=generate-a-long-random-string-here

# Supabase session pooler URL
# Format: postgresql://postgres.[PROJECT-REF]:[PASSWORD]@aws-0-[REGION].pooler.supabase.com:5432/postgres
DATABASE_URL=postgresql://postgres.yourproject:yourpassword@aws-0-us-east-1.pooler.supabase.com:5432/postgres?sslmode=require

# Redis (local: redis://localhost:6379/0 | Upstash: rediss://default:token@host:6379)
REDIS_URL=redis://localhost:6379/0

# Discord application — https://discord.com/developers/applications
DISCORD_CLIENT_ID=
DISCORD_CLIENT_SECRET=
DISCORD_BOT_TOKEN=

# Riot API — https://developer.riotgames.com
RIOT_API_KEY=

# Production only
# ALLOWED_HOSTS=discord-clash-api.onrender.com
# CORS_ALLOWED_ORIGINS=https://your-app.vercel.app
